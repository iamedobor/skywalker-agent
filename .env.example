# ─── LLM Provider (choose one or both) ──────────────────────────────────────
# Anthropic Claude (recommended — best vision reasoning)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT-4o (alternative)
OPENAI_API_KEY=sk-...

# Which provider to use: "anthropic" | "openai"
LLM_PROVIDER=anthropic

# Model name (defaults below are recommended)
# Fast + cheap:  claude-haiku-4-5-20251001  (recommended for most tasks)
# Powerful:      claude-sonnet-4-6
# For OpenAI:    gpt-4o
LLM_MODEL=claude-haiku-4-5-20251001

# ─── Agent Server ─────────────────────────────────────────────────────────────
PORT=3001
AGENT_TIMEOUT_MS=120000
MAX_STEPS=75 # Increase as needed or set to 0 for unlimited steps (be careful! API costs can spiral if the agent gets stuck) 

# ─── Browser ──────────────────────────────────────────────────────────────────
# "chromium" | "firefox" | "webkit"
BROWSER_TYPE=chromium

# Run headless (true = runs invisibly, screenshots stream to dashboard)
BROWSER_HEADLESS=true

# Use your existing Chrome profile (great for sites you're already logged into)
# BROWSER_USER_DATA_DIR=/Users/yourname/Library/Application Support/Google/Chrome

# ─── Frontend ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_AGENT_URL=http://localhost:3001
