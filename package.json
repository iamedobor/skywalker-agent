{
  "name": "skywalker",
  "version": "0.1.0",
  "private": true,
  "description": "The open-source Action-Model that turns natural language into browser actions",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "start": "turbo run start",
    "lint": "turbo run lint",
    "type-check": "turbo run type-check",
    "agent:dev": "pnpm --filter @skywalker/agent dev",
    "web:dev": "pnpm --filter @skywalker/web dev"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  }
}
